{
  "name": "importer",
  "version": "2.0.5",
  "private": true,
  "type": "module",
  "description": "Unified legacy database import utility for Inventory Management System",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "import:api": "tsx src/cli/api-import.ts",
    "import:sql": "tsx src/cli/sql-import.ts",
    "import": "tsx src/cli/import.ts import",
    "image-sync": "tsx src/cli/import.ts image-sync"
  },
  "dependencies": {
    "@types/turndown": "^5.0.6",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.2",
    "dotenv": "^17.4.2",
    "mysql2": "^3.22.0",
    "turndown": "^7.2.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "baseline-browser-mapping": "^2.10.18",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.8.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.0.10"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
